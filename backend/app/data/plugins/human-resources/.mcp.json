{
  "mcpServers": {
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp"
    },
    "google-workspace": {
      "type": "local",
      "command": ["uvx", "--from", "google-workspace-mcp", "google-workspace-worker"],
      "enabled": false
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "ms365": {
      "type": "local",
      "command": ["npx", "-y", "@softeria/ms-365-mcp-server"],
      "enabled": false
    }
  }
}
